@model BookStoreApp.Models.Category
@{
    ViewData["Title"] = "Xóa thể loại";
}

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Quản lý thể loại</a></li>
        <li class="breadcrumb-item active">Xóa: @Model.Name</li>
    </ol>
</nav>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card shadow-sm border-danger">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0"><i class="bi bi-exclamation-triangle me-2"></i>Xác nhận xóa thể loại</h5>
            </div>
            <div class="card-body">
                @if (Model.Books.Any())
                {
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-circle me-2"></i>
                        Không thể xóa thể loại này vì có <strong>@Model.Books.Count sách</strong> thuộc thể loại này.
                        Vui lòng chuyển các sách sang thể loại khác trước khi xóa.
                    </div>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left me-2"></i>Quay lại
                    </a>
                }
                else
                {
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-circle me-2"></i>
                        Bạn có chắc chắn muốn xóa thể loại này? Hành động này không thể hoàn tác.
                    </div>

                    <dl class="row mb-4">
                        <dt class="col-sm-4">Tên thể loại:</dt>
                        <dd class="col-sm-8 fw-bold">@Model.Name</dd>
                        <dt class="col-sm-4">Mô tả:</dt>
                        <dd class="col-sm-8">@(Model.Description ?? "-")</dd>
                    </dl>

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash me-2"></i>Xác nhận xóa
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle me-2"></i>Hủy
                            </a>
                        </div>
                    </form>
                }
            </div>
        </div>
    </div>
</div>
