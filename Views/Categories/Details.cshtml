@model BookStoreApp.Models.Category
@{
    ViewData["Title"] = Model.Name;
}

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Quản lý thể loại</a></li>
        <li class="breadcrumb-item active">@Model.Name</li>
    </ol>
</nav>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-bookmark me-2"></i>@Model.Name</h5>
        <div>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-light btn-sm">
                <i class="bi bi-pencil me-1"></i>Sửa
            </a>
        </div>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <p class="text-muted">@Model.Description</p>
        }
        <p><strong>Số sách trong thể loại:</strong> @Model.Books.Count</p>
    </div>
</div>

@if (Model.Books.Any())
{
    <h4 class="mb-3">Danh sách sách thuộc thể loại</h4>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
        @foreach (var book in Model.Books)
        {
            <div class="col">
                <partial name="_BookCardPartial" model="book" />
            </div>
        }
    </div>
}
else
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>Chưa có sách nào thuộc thể loại này.
    </div>
}
