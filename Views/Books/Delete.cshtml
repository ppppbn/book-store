@model BookStoreApp.Models.Book
@{
    ViewData["Title"] = "Xóa sách";
}

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Manage">Quản lý sách</a></li>
        <li class="breadcrumb-item active">Xóa: @Model.Title</li>
    </ol>
</nav>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card shadow-sm border-danger">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0"><i class="bi bi-exclamation-triangle me-2"></i>Xác nhận xóa sách</h5>
            </div>
            <div class="card-body">
                <div class="alert alert-warning">
                    <i class="bi bi-exclamation-circle me-2"></i>
                    Bạn có chắc chắn muốn xóa sách này? Hành động này không thể hoàn tác.
                </div>

                <div class="d-flex gap-3 mb-4">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl) && Model.ImageUrl.StartsWith("http"))
                    {
                        <img src="@Model.ImageUrl" class="img-thumbnail" style="width: 100px; height: 130px; object-fit: cover;"
                             onerror="this.style.display='none';this.nextElementSibling.classList.add('show');">
                        <div class="img-fallback bg-light align-items-center justify-content-center img-thumbnail" style="width: 100px; height: 130px;">
                            <i class="bi bi-book text-muted fs-1"></i>
                        </div>
                    }
                    else
                    {
                        <div class="bg-light d-flex align-items-center justify-content-center img-thumbnail" style="width: 100px; height: 130px;">
                            <i class="bi bi-book text-muted fs-1"></i>
                        </div>
                    }
                    <div>
                        <h5>@Model.Title</h5>
                        <p class="text-muted mb-1"><i class="bi bi-person me-1"></i>@Model.Author</p>
                        @if (Model.Category != null)
                        {
                            <p class="text-muted mb-1"><i class="bi bi-bookmark me-1"></i>@Model.Category.Name</p>
                        }
                        <p class="text-primary fw-bold mb-0">@Model.Price.ToString("N0") ₫</p>
                    </div>
                </div>

                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash me-2"></i>Xác nhận xóa
                        </button>
                        <a asp-action="Manage" class="btn btn-outline-secondary">
                            <i class="bi bi-x-circle me-2"></i>Hủy
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
