@model BookStoreApp.Models.Book
@{
    ViewData["Title"] = "Sửa thông tin sách";
}

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Manage">Quản lý sách</a></li>
        <li class="breadcrumb-item active">Sửa: @Model.Title</li>
    </ol>
</nav>

<div class="row">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-pencil me-2"></i>Sửa thông tin sách</h5>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="CreatedAt" />

                    <div class="row">
                        <div class="col-md-8 mb-3">
                            <label asp-for="Title" class="form-label"></label><span class="text-danger">*</span>
                            <input asp-for="Title" class="form-control" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="CategoryId" class="form-label"></label><span class="text-danger">*</span>
                            <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId">
                                <option value="">-- Chọn thể loại --</option>
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Author" class="form-label"></label><span class="text-danger">*</span>
                            <input asp-for="Author" class="form-control" />
                            <span asp-validation-for="Author" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Publisher" class="form-label"></label>
                            <input asp-for="Publisher" class="form-control" />
                            <span asp-validation-for="Publisher" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="Price" class="form-label"></label><span class="text-danger">*</span>
                            <div class="input-group">
                                <input asp-for="Price" class="form-control" />
                                <span class="input-group-text">₫</span>
                            </div>
                            <span asp-validation-for="Price" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="StockQuantity" class="form-label"></label><span class="text-danger">*</span>
                            <input asp-for="StockQuantity" class="form-control" />
                            <span asp-validation-for="StockQuantity" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="PublishedYear" class="form-label"></label>
                            <input asp-for="PublishedYear" class="form-control" />
                            <span asp-validation-for="PublishedYear" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ImageUrl" class="form-label"></label>
                        <input asp-for="ImageUrl" class="form-control" />
                        <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label"></label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle me-2"></i>Lưu thay đổi
                        </button>
                        <a asp-action="Manage" class="btn btn-outline-secondary">
                            <i class="bi bi-x-circle me-2"></i>Hủy
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        @if (!string.IsNullOrEmpty(Model.ImageUrl) && Model.ImageUrl.StartsWith("http"))
        {
            <div class="card shadow-sm">
                <div class="card-header">
                    <h6 class="mb-0">Ảnh bìa hiện tại</h6>
                </div>
                <div class="card-body text-center">
                    <img src="@Model.ImageUrl" class="img-fluid rounded" alt="@Model.Title"
                         onerror="this.style.display='none';this.nextElementSibling.classList.add('show');">
                    <div class="img-fallback align-items-center justify-content-center bg-light rounded" style="height: 200px;">
                        <i class="bi bi-book text-muted" style="font-size: 4rem;"></i>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
