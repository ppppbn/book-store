@model BookStoreApp.ViewModels.OrderListViewModel
@{
    ViewData["Title"] = "Đơn hàng của tôi";
}

<h2 class="mb-4"><i class="bi bi-receipt me-2"></i>Đơn hàng của tôi</h2>

@if (Model.Orders.Any())
{
    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Mã đơn</th>
                            <th>Ngày đặt</th>
                            <th>Tổng tiền</th>
                            <th>Trạng thái</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model.Orders)
                        {
                            <tr>
                                <td><strong>#@order.Id</strong></td>
                                <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="text-primary fw-bold">@order.TotalAmount.ToString("N0") ₫</td>
                                <td>
                                    @{
                                        var badgeClass = order.Status switch
                                        {
                                            BookStoreApp.Models.Enums.OrderStatus.Pending => "bg-warning text-dark",
                                            BookStoreApp.Models.Enums.OrderStatus.Confirmed => "bg-info",
                                            BookStoreApp.Models.Enums.OrderStatus.Shipping => "bg-primary",
                                            BookStoreApp.Models.Enums.OrderStatus.Completed => "bg-success",
                                            BookStoreApp.Models.Enums.OrderStatus.Cancelled => "bg-danger",
                                            _ => "bg-secondary"
                                        };
                                    }
                                    <span class="badge @badgeClass">@order.StatusDisplay</span>
                                </td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@order.Id" asp-route-from="myorders" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye me-1"></i>Chi tiết
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.TotalPages > 1)
            {
                <nav aria-label="Phân trang" class="mt-4">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="MyOrders" asp-route-page="@(Model.Page - 1)">Trước</a>
                        </li>
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.Page ? "active" : "")">
                                <a class="page-link" asp-action="MyOrders" asp-route-page="@i">@i</a>
                            </li>
                        }
                        <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="MyOrders" asp-route-page="@(Model.Page + 1)">Sau</a>
                        </li>
                    </ul>
                </nav>
            }
        </div>
    </div>
}
else
{
    <div class="text-center py-5">
        <i class="bi bi-bag-x text-muted" style="font-size: 5rem;"></i>
        <h3 class="mt-4">Chưa có đơn hàng nào</h3>
        <p class="text-muted">Bạn chưa đặt đơn hàng nào.</p>
        <a asp-controller="Books" asp-action="Index" class="btn btn-primary btn-lg">
            <i class="bi bi-book me-2"></i>Bắt đầu mua sắm
        </a>
    </div>
}
