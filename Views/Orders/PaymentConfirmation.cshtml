@model BookStoreApp.Models.Order
@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<div class="text-center py-5">
    <div class="mb-4">
        <i class="bi bi-check-circle text-success" style="font-size: 6rem;"></i>
    </div>
    <h1 class="text-success">Đặt hàng thành công!</h1>
    <p class="lead text-muted">Cảm ơn bạn đã mua sắm tại Nhà Sách Online</p>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0"><i class="bi bi-receipt me-2"></i>Thông tin đơn hàng #@Model.Id</h5>
            </div>
            <div class="card-body">
                <div class="row mb-4">
                    <div class="col-md-6">
                        <p class="mb-1"><strong>Ngày đặt:</strong> @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
                        <p class="mb-1"><strong>Trạng thái:</strong> 
                            <span class="badge bg-warning text-dark">@Model.StatusDisplay</span>
                        </p>
                        <p class="mb-1"><strong>Phương thức thanh toán:</strong> 
                            @(Model.PaymentMethod == "COD" ? "Thanh toán khi nhận hàng" : "Chuyển khoản ngân hàng")
                        </p>
                    </div>
                    <div class="col-md-6">
                        <p class="mb-1"><strong>Địa chỉ giao hàng:</strong></p>
                        <p class="text-muted">@Model.ShippingAddress</p>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.Note))
                {
                    <p><strong>Ghi chú:</strong> @Model.Note</p>
                }

                <hr>

                <h6 class="mb-3">Chi tiết sản phẩm:</h6>
                <table class="table">
                    <thead class="table-light">
                        <tr>
                            <th>Sản phẩm</th>
                            <th class="text-center">Số lượng</th>
                            <th class="text-end">Đơn giá</th>
                            <th class="text-end">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var detail in Model.OrderDetails)
                        {
                            <tr>
                                <td>@detail.Book?.Title</td>
                                <td class="text-center">@detail.Quantity</td>
                                <td class="text-end">@detail.UnitPrice.ToString("N0") ₫</td>
                                <td class="text-end">@detail.SubTotal.ToString("N0") ₫</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="3" class="text-end"><strong>Tổng cộng:</strong></td>
                            <td class="text-end"><strong class="text-success fs-5">@Model.TotalAmount.ToString("N0") ₫</strong></td>
                        </tr>
                    </tfoot>
                </table>

                @if (Model.PaymentMethod == "BankTransfer")
                {
                    <div class="alert alert-info mt-4">
                        <h6><i class="bi bi-bank me-2"></i>Thông tin chuyển khoản:</h6>
                        <p class="mb-1"><strong>Ngân hàng:</strong> Vietcombank</p>
                        <p class="mb-1"><strong>Số tài khoản:</strong> 1234567890</p>
                        <p class="mb-1"><strong>Chủ tài khoản:</strong> CONG TY TNHH NHA SACH ONLINE</p>
                        <p class="mb-0"><strong>Nội dung:</strong> Thanh toan DH @Model.Id</p>
                    </div>
                }
            </div>
        </div>

        <div class="d-flex justify-content-center gap-3">
            <a asp-action="MyOrders" class="btn btn-primary">
                <i class="bi bi-list-ul me-2"></i>Xem đơn hàng của tôi
            </a>
            <a asp-controller="Books" asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-book me-2"></i>Tiếp tục mua sắm
            </a>
        </div>
    </div>
</div>
