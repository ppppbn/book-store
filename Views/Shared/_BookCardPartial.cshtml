@model BookStoreApp.Models.Book
@{
    var hideAction = ViewData["HideAction"] as bool? ?? false;
}

<div class="card book-card h-100">
    <a href="@Url.Action("Details", "Books", new { id = Model.Id })" class="text-decoration-none">
        @if (!string.IsNullOrEmpty(Model.ImageUrl) && Model.ImageUrl.StartsWith("http"))
        {
            <img src="@Model.ImageUrl" class="card-img-top book-image" alt="@Model.Title" 
                 onerror="this.style.display='none';this.nextElementSibling.classList.add('show');">
            <div class="book-image-placeholder img-fallback">
                <i class="bi bi-book"></i>
            </div>
        }
        else
        {
            <div class="book-image-placeholder" style="display: flex;">
                <i class="bi bi-book"></i>
            </div>
        }
    </a>
    <div class="card-body d-flex flex-column">
        <div class="card-title">
            <a href="@Url.Action("Details", "Books", new { id = Model.Id })">@Model.Title</a>
        </div>
        <p class="text-muted small mb-2">
            <i class="bi bi-person me-1"></i>@Model.Author
        </p>
        @if (Model.Category != null && !hideAction)
        {
            <p class="mb-2">
                <span class="badge bg-secondary">@Model.Category.Name</span>
            </p>
        }
        @if (!hideAction)
        {
            <div class="mt-auto">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="price">@Model.Price.ToString("N0")₫</span>
                    @if (Model.StockQuantity > 0)
                    {
                        <small class="stock-status text-success">
                            <i class="bi bi-check-circle-fill"></i> Còn hàng
                        </small>
                    }
                    else
                    {
                        <small class="stock-status text-danger">
                            <i class="bi bi-x-circle-fill"></i> Hết hàng
                        </small>
                    }
                </div>
                @if (Model.StockQuantity > 0)
                {
                    <button class="btn btn-primary add-to-cart-btn w-100" 
                            data-book-id="@Model.Id"
                            onclick="addToCart(@Model.Id)">
                        <i class="bi bi-bag-plus me-1"></i>Thêm vào giỏ
                    </button>
                }
                else
                {
                    <button class="btn btn-secondary w-100" disabled>
                        <i class="bi bi-x-circle me-1"></i>Hết hàng
                    </button>
                }
            </div>
        }
        else
        {
            <div class="mt-auto pt-2 border-top">
                <div class="d-flex justify-content-between align-items-center">
                    <span class="price fs-6 fw-bold text-primary">@Model.Price.ToString("N0")₫</span>
                    <small class="text-muted">Kho: @Model.StockQuantity</small>
                </div>
            </div>
        }
    </div>
</div>
