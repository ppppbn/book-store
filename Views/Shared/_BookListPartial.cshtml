@model BookStoreApp.ViewModels.BookSearchViewModel

<input type="hidden" id="totalItemsCount" value="@Model.TotalItems" />

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4" id="bookList">
    @if (Model.Books.Any())
    {
        @foreach (var book in Model.Books)
        {
            <div class="col">
                <partial name="_BookCardPartial" model="book" />
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center py-5">
            <i class="bi bi-search fs-1 text-muted"></i>
            <p class="text-muted mt-3">Không tìm thấy sách nào phù hợp.</p>
        </div>
    }
</div>

@if (Model.TotalPages > 1)
{
    <partial name="_PaginationPartial" model="Model" />
}
