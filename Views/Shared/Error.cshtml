@model ErrorViewModel
@{
    ViewData["Title"] = "Lỗi";
}

<div class="text-center py-5">
    <i class="bi bi-exclamation-triangle text-danger" style="font-size: 5rem;"></i>
    <h1 class="mt-4">Đã xảy ra lỗi</h1>
    <p class="text-muted">Rất tiếc, đã có lỗi xảy ra trong quá trình xử lý yêu cầu của bạn.</p>

    @if (Model?.RequestId != null)
    {
        <p class="small text-muted">
            <strong>Request ID:</strong> @Model.RequestId
        </p>
    }

    <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-3">
        <i class="bi bi-house me-2"></i>Về trang chủ
    </a>
</div>
