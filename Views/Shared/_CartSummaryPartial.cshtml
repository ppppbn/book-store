@model BookStoreApp.ViewModels.CartViewModel

<div class="card">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0"><i class="bi bi-cart3 me-2"></i>Giỏ hàng của bạn</h5>
    </div>
    <div class="card-body">
        @if (Model.Items.Any())
        {
            <ul class="list-group list-group-flush">
                @foreach (var item in Model.Items.Take(3))
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                        <div class="d-flex align-items-center">
                            <span class="badge bg-secondary me-2">@item.Quantity</span>
                            <span class="text-truncate" style="max-width: 150px;">@item.Book?.Title</span>
                        </div>
                        <span class="text-primary fw-bold">@item.SubTotal.ToString("N0") ₫</span>
                    </li>
                }
                @if (Model.Items.Count > 3)
                {
                    <li class="list-group-item text-muted px-0">
                        <small>và @(Model.Items.Count - 3) sản phẩm khác...</small>
                    </li>
                }
            </ul>
            <hr>
            <div class="d-flex justify-content-between align-items-center">
                <strong>Tổng cộng:</strong>
                <strong class="text-primary fs-5">@Model.TotalAmount.ToString("N0") ₫</strong>
            </div>
            <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-primary w-100 mt-3">
                <i class="bi bi-cart me-1"></i>Xem giỏ hàng
            </a>
        }
        else
        {
            <div class="text-center text-muted py-3">
                <i class="bi bi-cart-x fs-1"></i>
                <p class="mt-2">Giỏ hàng trống</p>
            </div>
        }
    </div>
</div>
