@model BookStoreApp.ViewModels.StatisticsViewModel
@{
    ViewData["Title"] = "Thống kê";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-graph-up-arrow text-primary me-2"></i>Thống kê tổng quan</h2>
    <span class="badge bg-primary">Cập nhật: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</span>
</div>

<!-- Overview Cards -->
<div class="row g-4 mb-4">
    <div class="col-md-6 col-lg-3">
        <div class="stat-card primary">
            <div class="d-flex justify-content-between align-items-center position-relative" style="z-index: 1;">
                <div>
                    <p class="mb-1 opacity-75">Tổng sách</p>
                    <h2 class="mb-0">@Model.TotalBooks</h2>
                </div>
                <i class="bi bi-book"></i>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="stat-card success">
            <div class="d-flex justify-content-between align-items-center position-relative" style="z-index: 1;">
                <div>
                    <p class="mb-1 opacity-75">Tổng đơn hàng</p>
                    <h2 class="mb-0">@Model.TotalOrders</h2>
                </div>
                <i class="bi bi-box-seam"></i>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="stat-card info">
            <div class="d-flex justify-content-between align-items-center position-relative" style="z-index: 1;">
                <div>
                    <p class="mb-1 opacity-75">Khách hàng</p>
                    <h2 class="mb-0">@Model.TotalCustomers</h2>
                </div>
                <i class="bi bi-people"></i>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="stat-card warning">
            <div class="d-flex justify-content-between align-items-center position-relative" style="z-index: 1;">
                <div>
                    <p class="mb-1 opacity-75">Tổng doanh thu</p>
                    <h4 class="mb-0">@Model.TotalRevenue.ToString("N0")₫</h4>
                </div>
                <i class="bi bi-currency-dollar"></i>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <!-- Revenue Stats -->
    <div class="col-lg-8">
        <div class="card h-100">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-cash-stack me-2"></i>Doanh thu</h5>
            </div>
            <div class="card-body">
                <div class="row text-center mb-4">
                    <div class="col-md-4">
                        <div class="p-3 rounded" style="background: linear-gradient(135deg, rgba(16, 185, 129, 0.1) 0%, rgba(52, 211, 153, 0.1) 100%);">
                            <p class="text-muted mb-1 small">Tháng này</p>
                            <h4 class="text-success mb-0">@Model.RevenueThisMonth.ToString("N0")₫</h4>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="p-3 rounded" style="background: linear-gradient(135deg, rgba(99, 102, 241, 0.1) 0%, rgba(168, 85, 247, 0.1) 100%);">
                            <p class="text-muted mb-1 small">Tháng trước</p>
                            <h4 class="text-primary mb-0">@Model.RevenueLastMonth.ToString("N0")₫</h4>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="p-3 rounded" style="background: linear-gradient(135deg, rgba(245, 158, 11, 0.1) 0%, rgba(251, 191, 36, 0.1) 100%);">
                            <p class="text-muted mb-1 small">Tổng cộng</p>
                            <h4 class="text-warning mb-0">@Model.TotalRevenue.ToString("N0")₫</h4>
                        </div>
                    </div>
                </div>

                <h6 class="text-muted mb-3"><i class="bi bi-bar-chart me-2"></i>Doanh thu 6 tháng gần nhất</h6>
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Tháng</th>
                                <th class="text-center">Số đơn</th>
                                <th class="text-end">Doanh thu</th>
                                <th style="width: 35%;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var maxRevenue = Model.MonthlyRevenues.Any() ? Model.MonthlyRevenues.Max(m => m.Revenue) : 1;
                            }
                            @foreach (var month in Model.MonthlyRevenues)
                            {
                                var percentage = maxRevenue > 0 ? (month.Revenue / maxRevenue * 100) : 0;
                                <tr>
                                    <td class="fw-bold">@month.MonthName</td>
                                    <td class="text-center"><span class="badge bg-primary">@month.OrderCount</span></td>
                                    <td class="text-end text-success fw-bold">@month.Revenue.ToString("N0")₫</td>
                                    <td>
                                        <div class="progress">
                                            <div class="progress-bar" style="width: @percentage%"></div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Order Status -->
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-pie-chart me-2"></i>Đơn hàng theo trạng thái</h5>
            </div>
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between p-3 mb-2 rounded" style="background: linear-gradient(90deg, rgba(245, 158, 11, 0.15) 0%, transparent 100%);">
                    <span><i class="bi bi-hourglass-split text-warning me-2"></i>Chờ xác nhận</span>
                    <span class="badge bg-warning">@Model.PendingOrders</span>
                </div>
                <div class="d-flex align-items-center justify-content-between p-3 mb-2 rounded" style="background: linear-gradient(90deg, rgba(6, 182, 212, 0.15) 0%, transparent 100%);">
                    <span><i class="bi bi-check-circle text-info me-2"></i>Đã xác nhận</span>
                    <span class="badge bg-info">@Model.ConfirmedOrders</span>
                </div>
                <div class="d-flex align-items-center justify-content-between p-3 mb-2 rounded" style="background: linear-gradient(90deg, rgba(99, 102, 241, 0.15) 0%, transparent 100%);">
                    <span><i class="bi bi-truck text-primary me-2"></i>Đang giao</span>
                    <span class="badge bg-primary">@Model.ShippingOrders</span>
                </div>
                <div class="d-flex align-items-center justify-content-between p-3 mb-2 rounded" style="background: linear-gradient(90deg, rgba(16, 185, 129, 0.15) 0%, transparent 100%);">
                    <span><i class="bi bi-check-all text-success me-2"></i>Hoàn thành</span>
                    <span class="badge bg-success">@Model.CompletedOrders</span>
                </div>
                <div class="d-flex align-items-center justify-content-between p-3 rounded" style="background: linear-gradient(90deg, rgba(239, 68, 68, 0.15) 0%, transparent 100%);">
                    <span><i class="bi bi-x-circle text-danger me-2"></i>Đã hủy</span>
                    <span class="badge bg-danger">@Model.CancelledOrders</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Top Selling Books -->
<div class="card">
    <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-trophy me-2"></i>Top 10 sách bán chạy</h5>
    </div>
    <div class="card-body">
        @if (Model.TopSellingBooks.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th style="width: 50px;">#</th>
                            <th>Sách</th>
                            <th class="text-center">Đã bán</th>
                            <th class="text-end">Doanh thu</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.TopSellingBooks.Count; i++)
                        {
                            var book = Model.TopSellingBooks[i];
                            <tr>
                                <td>
                                    @if (i == 0)
                                    {
                                        <span class="badge" style="background: linear-gradient(135deg, #f59e0b 0%, #fbbf24 100%); font-size: 1rem;">
                                            <i class="bi bi-trophy-fill"></i>
                                        </span>
                                    }
                                    else if (i == 1)
                                    {
                                        <span class="badge" style="background: linear-gradient(135deg, #94a3b8 0%, #cbd5e1 100%); font-size: 1rem;">
                                            <i class="bi bi-trophy-fill"></i>
                                        </span>
                                    }
                                    else if (i == 2)
                                    {
                                        <span class="badge" style="background: linear-gradient(135deg, #d97706 0%, #f59e0b 100%); font-size: 1rem;">
                                            <i class="bi bi-trophy-fill"></i>
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@(i + 1)</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        @if (!string.IsNullOrEmpty(book.ImageUrl))
                                        {
                                            <img src="@book.ImageUrl" class="me-3 rounded" style="width: 45px; height: 60px; object-fit: cover; box-shadow: var(--shadow-sm);">
                                        }
                                        else
                                        {
                                            <div class="me-3 rounded bg-light d-flex align-items-center justify-content-center" style="width: 45px; height: 60px;">
                                                <i class="bi bi-book text-muted"></i>
                                            </div>
                                        }
                                        <div>
                                            <a href="@Url.Action("Details", "Books", new { id = book.BookId })" class="fw-bold text-decoration-none text-dark">
                                                @book.Title
                                            </a>
                                            <br><small class="text-muted">@book.Author</small>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-primary fs-6">@book.TotalSold</span>
                                </td>
                                <td class="text-end">
                                    <span class="fw-bold text-success">@book.TotalRevenue.ToString("N0")₫</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-bar-chart"></i>
                <h3>Chưa có dữ liệu bán hàng</h3>
                <p class="text-muted">Dữ liệu sẽ được cập nhật khi có đơn hàng hoàn thành.</p>
            </div>
        }
    </div>
</div>
